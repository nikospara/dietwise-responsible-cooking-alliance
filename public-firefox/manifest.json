{
	"name": "__MSG_extensionName__",
	"description": "__MSG_extensionDescription__",
	"default_locale": "en",
	"version": "1.0.0",
	"manifest_version": 3,
	"browser_specific_settings": {
		"gecko": {
			"id": "responsible-cooking-alliance@dietwise.eu"
		}
	},
	"action": {
		"default_title": "Click to open",
		"default_icon": {
			"16": "icons/DietWise_icon_LightGreen-16.png",
			"32": "icons/DietWise_icon_LightGreen-32.png"
		}
	},
	"background": {
		"scripts": ["background.js"]
	},
	"permissions": [
		"activeTab",
		"identity",
		"scripting",
		"storage",
		"tabs"
	],
	"host_permissions": [
		"<all_urls>"
	],
	"sidebar_action": {
		"default_title": "Responsible Cooking Alliance",
		"default_panel": "index.html",
		"default_icon": {
			"16": "icons/DietWise_icon_LightGreen-16.png",
			"32": "icons/DietWise_icon_LightGreen-32.png"
		}
	},
	"icons": {
		"16": "icons/DietWise_icon_LightGreen-16.png",
		"32": "icons/DietWise_icon_LightGreen-32.png",
		"48": "icons/DietWise_icon_LightGreen-48.png",
		"64": "icons/DietWise_icon_LightGreen-64.png",
		"96": "icons/DietWise_icon_LightGreen-96.png",
		"128": "icons/DietWise_icon_LightGreen-128.png"
	}
}
