{
  "name": "responsible-cooking-alliance",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist-chrome; rm -rf dist-firefox",
    "dev": "vite",
    "build-chrome": "tsc && VITE_TARGET_BROWSER=Chrome vite build",
    "build-chrome-with-sourcemaps": "tsc && VITE_TARGET_BROWSER=Chrome vite build --sourcemap true",
    "build-chrome-watch": "tsc && VITE_TARGET_BROWSER=Chrome VITE_WATCH=y vite build --sourcemap true",
    "build-firefox": "tsc && VITE_TARGET_BROWSER=Firefox vite build",
    "build-firefox-with-sourcemaps": "tsc && VITE_TARGET_BROWSER=Firefox vite build --sourcemap true",
    "build-firefox-watch": "tsc && VITE_TARGET_BROWSER=Firefox VITE_WATCH=y vite build --sourcemap true",
    "build-all": "tsc && VITE_TARGET_BROWSER=Chrome vite build && VITE_TARGET_BROWSER=Firefox vite build",
    "lint": "eslint",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "classnames": "2.5.1",
    "jotai": "^2.19.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^17.0.4",
    "react-icons": "^5.6.0",
    "react-markdown": "10.1.0",
    "turndown": "7.2.4"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.1",
    "@nabla/vite-plugin-eslint": "^3.0.1",
    "@tailwindcss/postcss": "4.2.4",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "0.1.40",
    "@types/eslint": "9.6.1",
    "@types/firefox-webext-browser": "143.0.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/turndown": "5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "10.5.0",
    "daisyui": "5.5.19",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "jsdom": "29.0.2",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.3",
    "tailwindcss": "4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-static-copy": "4.1.0",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "^4.1.5"
  }
}
