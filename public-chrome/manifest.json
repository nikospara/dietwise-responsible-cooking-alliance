{
	"name": "__MSG_extensionName__",
	"description": "__MSG_extensionDescription__",
	"default_locale": "en",
	"version": "1.0.0",
	"manifest_version": 3,
	"action": {
		"default_title": "Click to open",
		"default_icon": {
			"16": "icons/DietWise_icon_LightGreen-16.png",
			"32": "icons/DietWise_icon_LightGreen-32.png"
		}
	},
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": [
				"http://localhost:8180/extension-callback.html*",
				"https://dietwise.ispatial.survey.ntua.gr/extension-callback.html*"
			],
			"js": ["callback-content.js"],
			"run_at": "document_start"
		}
	],
	"permissions": [
		"activeTab",
		"scripting",
		"sidePanel",
		"storage",
		"tabs"
	],
	"host_permissions": [
		"<all_urls>"
	],
	"side_panel": {
		"default_path": "index.html"
	},
	"icons": {
		"16": "icons/DietWise_icon_LightGreen-16.png",
		"32": "icons/DietWise_icon_LightGreen-32.png",
		"48": "icons/DietWise_icon_LightGreen-48.png",
		"64": "icons/DietWise_icon_LightGreen-64.png",
		"96": "icons/DietWise_icon_LightGreen-96.png",
		"128": "icons/DietWise_icon_LightGreen-128.png"
	}
}
